{
    "name": "harvirsidhu/filament-action-overflow",
    "description": "Compose any Filament action list into primary actions plus an overflow dropdown, with divider support.",
    "keywords": [
        "harvirsidhu",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "filament-action-overflow",
        "action-overflow"
    ],
    "homepage": "https://github.com/harvirsidhu/filament-action-overflow",
    "support": {
        "issues": "https://github.com/harvirsidhu/filament-action-overflow/issues",
        "source": "https://github.com/harvirsidhu/filament-action-overflow"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "harvirsidhu",
            "email": "harvirsidhu@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0 || ^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0",
        "rector/rector": "^2.0",
        "spatie/laravel-ray": "^1.26"
    },
    "autoload": {
        "psr-4": {
            "Harvirsidhu\\FilamentActionOverflow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Harvirsidhu\\FilamentActionOverflow\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "phpstan analyse",
        "lint": "pint",
        "refactor": "rector",
        "test": "pest",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Harvirsidhu\\FilamentActionOverflow\\FilamentActionOverflowServiceProvider"
            ],
            "aliases": {
                "ActionOverflow": "Harvirsidhu\\FilamentActionOverflow\\Facades\\ActionOverflow"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
